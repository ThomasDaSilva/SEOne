    <div class="card-body">
        {{ form_start(category_form, {action: path('seone_config_category_configuration'), method: 'POST'}) }}
            <input type="hidden" name="{{ category_form.vars.full_name }}[success_url]" value="{{ path('admin.module.configure', {module_code: 'SEOne'}) }}">
            <input type="hidden" name="{{ category_form.vars.full_name }}[error_url]" value="{{ path('admin.module.configure', {module_code: 'SEOne'}) }}">
            {% do category_form.success_url.setRendered %}
            {% do category_form.error_url.setRendered %}


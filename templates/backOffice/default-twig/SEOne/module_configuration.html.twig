{# ============ Store SEO configuration ============ #}
<div class="card mb-4">
    <div class="card-header">
        <h5 class="card-title mb-0">{{ 'Configure Store'|trans({}, 'seone') }}</h5>
    </div>
    <div class="card-body">
        {{ form_start(store_form, {action: path('seone_config_store_configuration'), method: 'POST'}) }}
            <input type="hidden" name="{{ store_form.vars.full_name }}[success_url]" value="{{ path('admin.module.configure', {module_code: 'SEOne'}) }}">
            <input type="hidden" name="{{ store_form.vars.full_name }}[error_url]" value="{{ path('admin.module.configure', {module_code: 'SEOne'}) }}">
            {% do store_form.success_url.setRendered %}
            {% do store_form.error_url.setRendered %}

            {{ form_errors(store_form) }}

            <div class="row">
                <div class="col-md-4 mb-3">
                    {{ form_label(store_form.title) }}
                    {{ form_widget(store_form.title, {attr: {class: 'form-control'}}) }}
                </div>
                <div class="col-md-4 mb-3">
                    {{ form_label(store_form.description) }}
                    {{ form_widget(store_form.description, {attr: {class: 'form-control'}}) }}
                </div>
                <div class="col-md-4 mb-3">
                    {{ form_label(store_form.keywords) }}
                    {{ form_widget(store_form.keywords, {attr: {class: 'form-control'}}) }}
                </div>
            </div>

            <button type="submit" class="btn btn-primary">
                <i class="bi bi-save"></i> {{ 'Save'|trans({}, 'seone.bo.default') }}
            </button>
        {{ form_end(store_form) }}
    </div>
</div>

{# ============ Category configuration ============ #}
<div class="card mb-4">
    <div class="card-header">
        <h5 class="card-title mb-0">{{ 'Seo configuration'|trans({}, 'seone') }}</h5>
